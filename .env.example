# ==============================================================
# Madukotawatte Estate ERP - Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ==============================================================

# --- Database ---
DB_NAME=estate_erp
DB_USER=estate_user
DB_PASSWORD=change_me_secure_password

# --- JWT ---
# Generate a secure key: openssl rand -hex 64
JWT_SECRET=change_this_to_a_very_long_and_truly_random_secret_key_at_least_64_chars
JWT_EXPIRATION_MS=86400000   # 24 hours in milliseconds

# --- Server ---
SERVER_PORT=8080
